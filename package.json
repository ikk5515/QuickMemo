{
  "name": "quickmemo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && node scripts/copy-library-ocr-assets.mjs && npm run build:library-extension",
    "build:library-extension": "node scripts/build-library-extension.mjs --origin https://quickmemo-tan.vercel.app",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "security:functions-guard": "node scripts/security-functions-guard.mjs",
    "security:gitignore-guard": "node scripts/security-gitignore-guard.mjs",
    "test": "vitest run",
    "test:rules": "npx firebase-tools emulators:exec --project quickmemo-rules-test --only firestore,storage \"vitest run --config vitest.rules.config.ts\"",
    "emulators": "npx firebase-tools emulators:start --only auth,firestore,storage,hosting"
  },
  "overrides": {
    "@hono/node-server": "^2.0.11",
    "firebase-tools": {
      "js-yaml": "^4.2.0",
      "tmp": "^0.2.6",
      "uuid": "^11.1.1"
    },
    "tmp": "^0.2.6",
    "gaxios@6.7.1": {
      "uuid": "^11.1.1"
    },
    "morgan": "^1.11.0",
    "@google-cloud/pubsub": {
      "@opentelemetry/core": "^2.8.0"
    },
    "esbuild": "^0.28.1",
    "undici": "^6.27.0",
    "universal-analytics": {
      "uuid": "14.0.0"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tesseract.js-data/eng": "1.0.0",
    "@tesseract.js-data/kor": "1.0.0",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-table": "^3.23.4",
    "@tiptap/extension-table-cell": "^3.23.4",
    "@tiptap/extension-table-header": "^3.23.4",
    "@tiptap/extension-table-row": "^3.23.4",
    "@tiptap/extension-task-item": "^3.23.4",
    "@tiptap/extension-task-list": "^3.23.4",
    "@tiptap/extension-text-align": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@vercel/blob": "^2.4.0",
    "cfb": "^1.2.2",
    "docx-preview": "^0.3.7",
    "fflate": "^0.8.3",
    "firebase": "^12.6.0",
    "lucide-react": "^0.555.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^15.18.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.7"
  }
}
