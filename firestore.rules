rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function bootstrapPath() {
      return /databases/$(database)/documents/system/bootstrap;
    }

    function bootstrapGatePath() {
      return /databases/$(database)/documents/system/bootstrapGate;
    }

    function bootstrapAttemptPath(uid) {
      return /databases/$(database)/documents/system/bootstrapAttempts/attempts/$(uid);
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function rosterPath(uid) {
      return /databases/$(database)/documents/publicLoginRoster/$(uid);
    }

    function userKeyPath(uid) {
      return /databases/$(database)/documents/userKeys/$(uid);
    }

    function quickLoginKeyPath(quickKey) {
      return /databases/$(database)/documents/quickLoginKeys/$(quickKey);
    }

    function notePath(noteId) {
      return /databases/$(database)/documents/notes/$(noteId);
    }

    function noteFolderPath(folderId) {
      return /databases/$(database)/documents/noteFolders/$(folderId);
    }

    function publicSharePath(shareId) {
      return /databases/$(database)/documents/publicNoteShares/$(shareId);
    }

    function publicShareAttachmentPath(shareId, attachmentId) {
      return /databases/$(database)/documents/publicNoteShares/$(shareId)/attachments/$(attachmentId);
    }

    function publicShareCleanupQueuePath(shareId) {
      return /databases/$(database)/documents/publicShareCleanupQueue/$(shareId);
    }

    function publicShareAttachmentCleanupQueuePath(shareId, attachmentId) {
      return /databases/$(database)/documents/publicShareCleanupQueue/$(shareId)/publicShareAttachmentCleanupQueue/$(attachmentId);
    }

    function activeSignedInUser() {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && get(userPath(request.auth.uid)).data.isActive == true;
    }

    function adminUser() {
      return activeSignedInUser()
        && get(userPath(request.auth.uid)).data.isAdmin == true;
    }

    function noteParticipant(data) {
      return activeSignedInUser() && request.auth.uid in data.participantUids;
    }

    function encryptedPayload(payload) {
      return payload is map
        && payload.version == 1
        && payload.algorithm == "AES-GCM"
        && payload.cipherText is string
        && payload.iv is string;
    }

    function wrappedAesKeyPayload(payload) {
      return payload is map
        && payload.keys().hasOnly(["version", "algorithm", "wrappedKey"])
        && payload.version == 1
        && payload.algorithm == "RSA-OAEP"
        && payload.wrappedKey is string
        && payload.wrappedKey.size() >= 8
        && payload.wrappedKey.size() <= 4096;
    }

    function validNote(data) {
      return data.keys().hasOnly([
        "type",
        "ownerUid",
        "participantUids",
        "encryptedTitle",
        "encryptedBody",
        "wrappedKeys",
        "folderId",
        "createdAt",
        "dueAt",
        "updatedAt",
        "updatedBy",
        "savedAt",
        "isDeleted",
        "deletedAt",
        "deletedBy",
        "isPurged",
        "purgedAt",
        "purgedBy"
      ])
      && data.type in ["personal", "shared"]
      && data.ownerUid is string
      && data.participantUids is list
      && data.participantUids.size() > 0
      && ((data.type == "personal" && data.participantUids.size() == 1) || (data.type == "shared" && data.participantUids.size() > 1))
      && encryptedPayload(data.encryptedTitle)
      && encryptedPayload(data.encryptedBody)
      && data.wrappedKeys is map
      && validNoteFolderReference(data)
      && (!data.keys().hasAny(["createdAt"]) || data.createdAt is timestamp)
      && (!data.keys().hasAny(["dueAt"]) || data.dueAt == null || data.dueAt is timestamp)
      && (!data.keys().hasAny(["updatedAt"]) || data.updatedAt is timestamp)
      && (!data.keys().hasAny(["savedAt"]) || data.savedAt is timestamp)
      && data.updatedBy is string
      && validDeleteMetadata(data)
      && validPurgeMetadata(data);
    }

    function validNoteFolderReference(data) {
      return !data.keys().hasAny(["folderId"])
        || data.folderId == null
        || (
          data.type == "personal"
          && data.folderId is string
          && data.folderId.size() > 0
          && data.folderId.size() <= 120
        );
    }

    function validAssignedFolder(data) {
      return !data.keys().hasAny(["folderId"])
        || data.folderId == null
        || (
          data.folderId is string
          && exists(noteFolderPath(data.folderId))
          && get(noteFolderPath(data.folderId)).data.ownerUid == data.ownerUid
        );
    }

    function validDeleteMetadata(data) {
      return legacyActiveDeleteMetadata(data)
        || (
          data.keys().hasAny(["isDeleted"])
          && data.isDeleted == false
          && !data.keys().hasAny(["deletedAt", "deletedBy"])
        )
        || (
          data.keys().hasAll(["isDeleted", "deletedAt", "deletedBy"])
          && data.isDeleted == true
          && data.deletedAt is timestamp
          && data.deletedBy is string
          && data.deletedBy.size() > 0
        );
    }

    function legacyActiveDeleteMetadata(data) {
      return !data.keys().hasAny(["isDeleted", "deletedAt", "deletedBy"]);
    }

    function noteDeleted(data) {
      return data.keys().hasAny(["isDeleted"]) && data.isDeleted == true;
    }

    function noteActive(data) {
      return legacyActiveDeleteMetadata(data)
        || (data.keys().hasAny(["isDeleted"]) && data.isDeleted == false);
    }

    function notePurged(data) {
      return data.keys().hasAny(["isPurged"]) && data.isPurged == true;
    }

    function noteFolderId(data) {
      return data.keys().hasAny(["folderId"]) ? data.folderId : null;
    }

    function validPurgeMetadata(data) {
      return !data.keys().hasAny(["isPurged", "purgedAt", "purgedBy"])
        || (
          data.keys().hasAll(["isPurged", "purgedAt", "purgedBy"])
          && data.keys().hasAll(["isDeleted", "deletedAt", "deletedBy"])
          && data.isDeleted == true
          && data.isPurged == true
          && data.purgedAt is timestamp
          && data.purgedBy is string
          && data.purgedBy.size() > 0
        );
    }

    function validRoster(data, uid) {
      return data.keys().hasOnly([
        "uid",
        "displayName",
        "avatarText",
        "color",
        "order",
        "quickKey",
        "loginEmail",
        "isActive",
        "isAdmin"
      ])
      && data.uid == uid
      && data.displayName is string
      && data.displayName.size() > 0
      && data.displayName.size() <= 40
      && data.avatarText is string
      && data.avatarText.size() > 0
      && data.avatarText.size() <= 4
      && data.color is string
      && data.order is int
      && data.order >= 1
      && data.quickKey is int
      && data.quickKey >= 1
      && data.quickKey <= 99
      && data.loginEmail is string
      && data.isActive is bool
      && data.isAdmin is bool;
    }

    function validUserProfile(data, uid) {
      return data.keys().hasOnly([
        "uid",
        "displayName",
        "avatarText",
        "color",
        "order",
        "quickKey",
        "loginEmail",
        "isActive",
        "isAdmin",
        "role",
        "publicKeyJwk",
        "allowedShareTargetUids",
        "createdAt",
        "updatedAt",
        "needsKeyRecovery"
      ])
      && data.uid == uid
      && data.displayName is string
      && data.displayName.size() > 0
      && data.displayName.size() <= 40
      && data.avatarText is string
      && data.avatarText.size() > 0
      && data.avatarText.size() <= 4
      && data.color is string
      && data.order is int
      && data.order >= 1
      && data.quickKey is int
      && data.quickKey >= 1
      && data.quickKey <= 99
      && data.loginEmail is string
      && data.isActive is bool
      && data.isAdmin is bool
      && data.role in ["admin", "user"]
      && ((data.isAdmin == true && data.role == "admin") || (data.isAdmin == false && data.role == "user"))
      && data.publicKeyJwk is map
      && (
        !data.keys().hasAny(["allowedShareTargetUids"])
        || (
          data.allowedShareTargetUids is list
          && data.allowedShareTargetUids.size() <= 200
          && uid in data.allowedShareTargetUids
        )
      )
      && data.needsKeyRecovery is bool;
    }

    function validUserKey(data, uid) {
      return data.keys().hasOnly([
        "uid",
        "publicKeyJwk",
        "encryptedPrivateKeyJwk",
        "kdfSalt",
        "kdfIterations",
        "pendingEncryptedPrivateKeyJwk",
        "pendingKdfSalt",
        "pendingKdfIterations",
        "pendingCreatedAt",
        "updatedAt"
      ])
      && data.uid == uid
      && data.publicKeyJwk is map
      && encryptedPayload(data.encryptedPrivateKeyJwk)
      && data.kdfSalt is string
      && data.kdfIterations is int
      && data.kdfIterations >= 100000
      && (
        !data.keys().hasAny(["pendingEncryptedPrivateKeyJwk", "pendingKdfSalt", "pendingKdfIterations", "pendingCreatedAt"])
        || (
          data.keys().hasAll(["pendingEncryptedPrivateKeyJwk", "pendingKdfSalt", "pendingKdfIterations", "pendingCreatedAt"])
          && encryptedPayload(data.pendingEncryptedPrivateKeyJwk)
          && data.pendingKdfSalt is string
          && data.pendingKdfIterations is int
          && data.pendingKdfIterations >= 100000
          && data.pendingCreatedAt is timestamp
        )
      )
      && (!data.keys().hasAny(["updatedAt"]) || data.updatedAt is timestamp);
    }

    function validUserPreferences(data, uid) {
      return data.keys().hasOnly(["uid", "defaultHome", "scheduleDefaultView", "createdAt", "updatedAt"])
        && data.uid == uid
        && data.defaultHome in ["notes", "schedule"]
        && data.scheduleDefaultView in ["todo", "calendar", "matrix", "recurring", "completed"]
        && (!data.keys().hasAny(["createdAt"]) || data.createdAt is timestamp)
        && (!data.keys().hasAny(["updatedAt"]) || data.updatedAt is timestamp);
    }

    function validScheduleDate(value) {
      return value == null
        || (
          value is string
          && value.size() == 10
          && value.matches("^(((19|20|21)[0-9]{2}-((01|03|05|07|08|10|12)-(0[1-9]|[12][0-9]|3[01])|(04|06|09|11)-(0[1-9]|[12][0-9]|30)|02-(0[1-9]|1[0-9]|2[0-8])))|(((19|21)(0[48]|[2468][048]|[13579][26])|20(0[048]|[2468][048]|[13579][26]))-02-29))$")
        );
    }

    function validScheduleTime(value) {
      return value == null || (value is int && value >= 0 && value <= 1439);
    }

    function validScheduleColor(data) {
      return !data.keys().hasAny(["color"])
        || data.color == null
        || (
          data.color is string
          && data.color.matches("^#[0-9A-Fa-f]{6}$")
        );
    }

    function validScheduleSortOrder(data) {
      return !data.keys().hasAny(["sortOrder"])
        || data.sortOrder == null
        || (
          data.sortOrder is int
          && data.sortOrder >= 0
        );
    }

    function validScheduleProgress(data) {
      return !data.keys().hasAny(["progressPercent"])
        || data.progressPercent == null
        || (
          data.progressPercent is int
          && data.progressPercent >= 0
          && data.progressPercent <= 100
        );
    }

    function scheduleStartDate(data) {
      return data.keys().hasAny(["startDate"]) ? data.startDate : data.dueDate;
    }

    function scheduleEndDate(data) {
      return data.keys().hasAny(["endDate"]) ? data.endDate : scheduleStartDate(data);
    }

    function scheduleStartTime(data) {
      return data.keys().hasAny(["startTimeMinutes"]) ? data.startTimeMinutes : data.dueTimeMinutes;
    }

    function scheduleEndTime(data) {
      return data.keys().hasAny(["endTimeMinutes"]) ? data.endTimeMinutes : null;
    }

    function scheduleDateYear(value) {
      return value.split("-")[0];
    }

    function validScheduleRangeLength(data) {
      return scheduleStartDate(data) == null
        || scheduleEndDate(data) == null
        || scheduleDateYear(scheduleStartDate(data)) == scheduleDateYear(scheduleEndDate(data));
    }

    function validScheduleDateRange(data) {
      return validScheduleDate(data.dueDate)
        && validScheduleDate(scheduleStartDate(data))
        && validScheduleDate(scheduleEndDate(data))
        && validScheduleRangeLength(data)
        && (
          scheduleStartDate(data) == null
          || scheduleEndDate(data) == null
          || scheduleEndDate(data) >= scheduleStartDate(data)
        )
        && (
          scheduleStartDate(data) == data.dueDate
          || (scheduleStartDate(data) == null && data.dueDate == null)
        );
    }

    function validScheduleTimeRange(data) {
      return validScheduleTime(data.dueTimeMinutes)
        && validScheduleTime(scheduleStartTime(data))
        && validScheduleTime(scheduleEndTime(data))
        && (
          scheduleStartTime(data) == data.dueTimeMinutes
          || (scheduleStartTime(data) == null && data.dueTimeMinutes == null)
        )
        && (
          scheduleEndTime(data) == null
          || (
            scheduleStartTime(data) != null
            && scheduleEndTime(data) >= scheduleStartTime(data)
          )
        );
    }

    function encryptedSchedulePayload(payload, maxCipherTextSize) {
      return encryptedPayload(payload)
        && payload.cipherText.size() > 0
        && payload.cipherText.size() <= maxCipherTextSize
        && payload.iv.size() > 0
        && payload.iv.size() <= 256;
    }

    function validScheduleWrappedKeys(data, uid) {
      return data.wrappedKeys is map
        && data.wrappedKeys.keys().hasOnly([uid])
        && wrappedAesKeyPayload(data.wrappedKeys[uid]);
    }

    function validScheduleCompletion(data) {
      return (
        data.status == "active"
        && data.completedAt == null
      )
      || (
        data.status == "completed"
        && data.completedAt is timestamp
        && data.completedAt <= request.time
      );
    }

    function validScheduleTask(data, uid) {
      return data.keys().hasAll([
        "ownerUid",
        "status",
        "dueDate",
        "dueTimeMinutes",
        "isImportant",
        "isUrgent",
        "encryptedTitle",
        "encryptedDetails",
        "wrappedKeys",
        "createdBy",
        "updatedBy",
        "createdAt",
        "updatedAt",
        "completedAt"
      ])
      && data.keys().hasOnly([
        "ownerUid",
        "status",
        "dueDate",
        "dueTimeMinutes",
        "startDate",
        "endDate",
        "startTimeMinutes",
        "endTimeMinutes",
        "color",
        "sortOrder",
        "progressPercent",
        "isImportant",
        "isUrgent",
        "encryptedTitle",
        "encryptedDetails",
        "wrappedKeys",
        "createdBy",
        "updatedBy",
        "createdAt",
        "updatedAt",
        "completedAt"
      ])
      && data.ownerUid == uid
      && data.status in ["active", "completed"]
      && validScheduleDateRange(data)
      && validScheduleTimeRange(data)
      && validScheduleColor(data)
      && validScheduleSortOrder(data)
      && validScheduleProgress(data)
      && data.isImportant is bool
      && data.isUrgent is bool
      && encryptedSchedulePayload(data.encryptedTitle, 4096)
      && encryptedSchedulePayload(data.encryptedDetails, 50000)
      && validScheduleWrappedKeys(data, uid)
      && data.createdBy == uid
      && data.updatedBy == uid
      && data.createdAt is timestamp
      && data.updatedAt is timestamp
      && validScheduleCompletion(data);
    }

    function validRecurringHabitColor(value) {
      return value is string
        && value.matches("^#[0-9A-Fa-f]{6}$");
    }

    function validRecurringHabitSortOrder(data) {
      return !data.keys().hasAny(["sortOrder"])
        || data.sortOrder == null
        || (
          data.sortOrder is int
          && data.sortOrder >= 0
          && data.sortOrder <= 1000000
        );
    }

    function validRecurringHabit(data, uid) {
      return data.keys().hasAll([
        "ownerUid",
        "status",
        "slot",
        "icon",
        "color",
        "encryptedTitle",
        "encryptedDetails",
        "wrappedKeys",
        "createdBy",
        "updatedBy",
        "createdAt",
        "updatedAt"
      ])
      && data.keys().hasOnly([
        "ownerUid",
        "status",
        "slot",
        "icon",
        "color",
        "sortOrder",
        "encryptedTitle",
        "encryptedDetails",
        "wrappedKeys",
        "createdBy",
        "updatedBy",
        "createdAt",
        "updatedAt"
      ])
      && data.ownerUid == uid
      && data.status in ["active", "archived"]
      && data.slot in ["morning", "afternoon", "other"]
      && data.icon in ["work", "study", "reading", "exercise", "health", "cleanup", "review", "other"]
      && validRecurringHabitColor(data.color)
      && validRecurringHabitSortOrder(data)
      && encryptedSchedulePayload(data.encryptedTitle, 4096)
      && encryptedSchedulePayload(data.encryptedDetails, 12000)
      && validScheduleWrappedKeys(data, uid)
      && data.createdBy == uid
      && data.updatedBy == uid
      && data.createdAt is timestamp
      && data.updatedAt is timestamp;
    }

    function recurringHabitBelongsToOwner(habitId, uid) {
      return exists(/databases/$(database)/documents/recurringHabits/$(habitId))
        && get(/databases/$(database)/documents/recurringHabits/$(habitId)).data.ownerUid == uid;
    }

    function validRecurringHabitCheckIn(data, uid, checkInId) {
      return data.keys().hasAll([
        "ownerUid",
        "habitId",
        "date",
        "checkedAt",
        "createdAt",
        "updatedAt"
      ])
      && data.keys().hasOnly([
        "ownerUid",
        "habitId",
        "date",
        "checkedAt",
        "createdAt",
        "updatedAt"
      ])
      && data.ownerUid == uid
      && data.habitId is string
      && data.habitId.size() > 0
      && data.habitId.size() <= 128
      && validScheduleDate(data.date)
      && data.date != null
      && checkInId == data.habitId + "_" + data.date
      && data.checkedAt is timestamp
      && data.checkedAt <= request.time
      && data.createdAt is timestamp
      && data.updatedAt is timestamp
      && recurringHabitBelongsToOwner(data.habitId, uid);
    }

    function validNoteFolder(data) {
      return data.keys().hasOnly(["ownerUid", "name", "color", "createdAt", "updatedAt"])
        && data.ownerUid == request.auth.uid
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 40
        && data.color is string
        && data.color.size() > 0
        && data.color.size() <= 24
        && (!data.keys().hasAny(["createdAt"]) || data.createdAt is timestamp)
        && (!data.keys().hasAny(["updatedAt"]) || data.updatedAt is timestamp);
    }

    function validQuickLoginKey(data, uid) {
      return data.keys().hasOnly(["uid", "quickKey", "createdAt", "updatedAt"])
      && data.uid == uid
      && data.quickKey is int
      && data.quickKey >= 1
      && data.quickKey <= 99;
    }

    function validActiveNote(data, uid) {
      return data.keys().hasAll(["uid", "noteId", "updatedByClientId"])
        && data.keys().hasOnly(["uid", "noteId", "updatedAt", "updatedByClientId"])
        && data.uid == uid
        && (data.noteId == null || data.noteId is string)
        && data.updatedByClientId is string
        && data.updatedByClientId.size() > 0
        && data.updatedByClientId.size() <= 80;
    }

    function validNoteUserState(data, noteId, uid) {
      return data.keys().hasAll(["uid", "noteId"])
        && data.keys().hasOnly([
          "uid",
          "noteId",
          "isPinned",
          "readAt",
          "confirmedAt",
          "cursorOffset",
          "cursorVisible",
          "cursorClientId",
          "cursorUpdatedAt",
          "updatedAt"
        ])
        && data.uid == uid
        && data.noteId == noteId
        && (!data.keys().hasAny(["isPinned"]) || data.isPinned is bool)
        && (!data.keys().hasAny(["readAt"]) || data.readAt is timestamp)
        && (!data.keys().hasAny(["confirmedAt"]) || data.confirmedAt is timestamp)
        && (
          !data.keys().hasAny(["cursorOffset"])
          || data.cursorOffset == null
          || (data.cursorOffset is int && data.cursorOffset >= 0 && data.cursorOffset <= 500000)
        )
        && (!data.keys().hasAny(["cursorVisible"]) || data.cursorVisible is bool)
        && (
          !data.keys().hasAny(["cursorClientId"])
          || (data.cursorClientId is string && data.cursorClientId.size() > 0 && data.cursorClientId.size() <= 80)
        )
        && (
          !data.keys().hasAny(["cursorUpdatedAt"])
          || (data.cursorUpdatedAt is timestamp && data.cursorUpdatedAt <= request.time)
        )
        && (!data.keys().hasAny(["updatedAt"]) || data.updatedAt is timestamp);
    }

    function validNoteHistory(data, noteId) {
      return data.keys().hasAll(["noteId", "actorUid", "action", "changedFields", "readerUids", "createdAt"])
        && data.keys().hasOnly(["noteId", "actorUid", "action", "changedFields", "readerUids", "encryptedSummary", "encryptedSnapshot", "createdAt"])
        && data.noteId == noteId
        && data.actorUid == request.auth.uid
        && data.action in ["create", "content", "share", "delete", "restore"]
        && data.changedFields is list
        && data.changedFields.size() > 0
        && data.changedFields.size() <= 8
        && data.changedFields.hasOnly(["title", "body", "participants", "deleted", "restored"])
        && data.readerUids is list
        && data.readerUids.size() > 0
        && data.readerUids.size() <= 200
        && (!data.keys().hasAny(["encryptedSummary"]) || encryptedPayload(data.encryptedSummary))
        && (!data.keys().hasAny(["encryptedSnapshot"]) || encryptedPayload(data.encryptedSnapshot))
        && data.createdAt == request.time;
    }

    function canReadNoteHistory(data, noteData) {
      return canReadNoteDocument(noteData)
        && (
          request.auth.uid == noteData.ownerUid
          || request.auth.uid in data.readerUids
        );
    }

    function linkedNoteUpdate(noteId) {
      return exists(notePath(noteId))
        && existsAfter(notePath(noteId))
        && getAfter(notePath(noteId)).data.updatedBy == request.auth.uid
        && getAfter(notePath(noteId)).data.updatedAt == request.time;
    }

    function createHistoryMatchesNote(data, noteId) {
      return data.action == "create"
        && !exists(notePath(noteId))
        && existsAfter(notePath(noteId))
        && getAfter(notePath(noteId)).data.ownerUid == request.auth.uid
        && getAfter(notePath(noteId)).data.updatedBy == request.auth.uid
        && getAfter(notePath(noteId)).data.createdAt == request.time
        && getAfter(notePath(noteId)).data.updatedAt == request.time
        && getAfter(notePath(noteId)).data.savedAt == request.time
        && getAfter(notePath(noteId)).data.isDeleted == false
        && data.changedFields.hasOnly(["title", "body"]);
    }

    function contentHistoryMatchesNote(data, noteId) {
      return data.action == "content"
        && linkedNoteUpdate(noteId)
        && !noteDeleted(get(notePath(noteId)).data)
        && !noteDeleted(getAfter(notePath(noteId)).data)
        && data.changedFields.hasOnly(["title", "body"])
        && getAfter(notePath(noteId)).data.type == get(notePath(noteId)).data.type
        && getAfter(notePath(noteId)).data.participantUids == get(notePath(noteId)).data.participantUids
        && getAfter(notePath(noteId)).data.wrappedKeys == get(notePath(noteId)).data.wrappedKeys
        && noteFolderId(getAfter(notePath(noteId)).data) == noteFolderId(get(notePath(noteId)).data)
        && (
          getAfter(notePath(noteId)).data.encryptedTitle != get(notePath(noteId)).data.encryptedTitle
          || getAfter(notePath(noteId)).data.encryptedBody != get(notePath(noteId)).data.encryptedBody
        );
    }

    function shareHistoryMatchesNote(data, noteId) {
      return data.action == "share"
        && linkedNoteUpdate(noteId)
        && request.auth.uid == get(notePath(noteId)).data.ownerUid
        && !noteDeleted(get(notePath(noteId)).data)
        && !noteDeleted(getAfter(notePath(noteId)).data)
        && data.changedFields.hasOnly(["participants"])
        && getAfter(notePath(noteId)).data.encryptedTitle == get(notePath(noteId)).data.encryptedTitle
        && getAfter(notePath(noteId)).data.encryptedBody == get(notePath(noteId)).data.encryptedBody
        && (
          getAfter(notePath(noteId)).data.type != get(notePath(noteId)).data.type
          || getAfter(notePath(noteId)).data.participantUids != get(notePath(noteId)).data.participantUids
          || getAfter(notePath(noteId)).data.wrappedKeys != get(notePath(noteId)).data.wrappedKeys
          || noteFolderId(getAfter(notePath(noteId)).data) != noteFolderId(get(notePath(noteId)).data)
        );
    }

    function deleteHistoryMatchesNote(data, noteId) {
      return data.action == "delete"
        && linkedNoteUpdate(noteId)
        && !noteDeleted(get(notePath(noteId)).data)
        && noteDeleted(getAfter(notePath(noteId)).data)
        && getAfter(notePath(noteId)).data.deletedBy == request.auth.uid
        && data.changedFields.hasOnly(["deleted"]);
    }

    function restoreHistoryMatchesNote(data, noteId) {
      return data.action == "restore"
        && linkedNoteUpdate(noteId)
        && noteDeleted(get(notePath(noteId)).data)
        && !noteDeleted(getAfter(notePath(noteId)).data)
        && data.changedFields.hasOnly(["restored"]);
    }

    function historyMatchesNoteMutation(data, noteId) {
      return existsAfter(notePath(noteId))
        && data.readerUids == getAfter(notePath(noteId)).data.participantUids
        && (
          createHistoryMatchesNote(data, noteId)
          || contentHistoryMatchesNote(data, noteId)
          || shareHistoryMatchesNote(data, noteId)
          || deleteHistoryMatchesNote(data, noteId)
          || restoreHistoryMatchesNote(data, noteId)
        );
    }

    function validAttachment(data, noteId) {
      return data.keys().hasOnly([
        "noteId",
        "version",
        "algorithm",
        "fileName",
        "extension",
        "mimeType",
        "originalSize",
        "encryptedData",
        "iv",
        "uploadedBy",
        "createdAt"
      ])
      && data.noteId == noteId
      && data.version == 1
      && data.algorithm == "AES-GCM"
      && data.fileName is string
      && data.fileName.size() > 0
      && data.fileName.size() <= 100
      && data.extension in [
        "pdf",
        "txt",
        "md",
        "csv",
        "json",
        "doc",
        "docx",
        "xls",
        "xlsx",
        "ppt",
        "pptx",
        "hwp",
        "hwpx",
        "png",
        "jpg",
        "jpeg",
        "webp",
        "gif"
      ]
      && data.mimeType is string
      && data.mimeType.size() <= 120
      && data.originalSize is int
      && data.originalSize > 0
      && data.originalSize <= 1000000
      && data.encryptedData is bytes
      && data.encryptedData.size() == data.originalSize + 16
      && data.encryptedData.size() <= 1000016
      && data.iv is bytes
      && data.iv.size() == 12
      && data.uploadedBy is string
      && data.uploadedBy.size() > 0
      && (!data.keys().hasAny(["createdAt"]) || data.createdAt is timestamp);
    }

    function validPublicShare(data) {
      return data.keys().hasOnly([
        "sourceNoteId",
        "ownerUid",
        "version",
        "encryptedTitle",
        "encryptedBody",
        "ownerWrappedShareKey",
        "attachmentCount",
        "passwordHash",
        "ready",
        "createdAt",
        "updatedAt",
        "expiresAt",
        "revokedAt",
        "revokedBy"
      ])
      && data.sourceNoteId is string
      && data.sourceNoteId.size() > 0
      && data.sourceNoteId.size() <= 160
      && data.ownerUid is string
      && data.ownerUid.size() > 0
      && data.version == 1
      && encryptedPayload(data.encryptedTitle)
      && encryptedPayload(data.encryptedBody)
      && validPublicShareOwnerWrappedKey(data)
      && data.attachmentCount is int
      && data.attachmentCount >= 0
      && data.attachmentCount <= 100
      && validPublicSharePassword(data)
      && data.ready is bool
      && (!data.keys().hasAny(["createdAt"]) || data.createdAt is timestamp)
      && (!data.keys().hasAny(["updatedAt"]) || data.updatedAt is timestamp)
      && data.expiresAt is timestamp
      && (
        !data.keys().hasAny(["revokedAt", "revokedBy"])
        || (
          data.keys().hasAll(["revokedAt", "revokedBy"])
          && data.revokedAt is timestamp
          && data.revokedBy is string
          && data.revokedBy.size() > 0
        )
      );
    }

    function publicSharePasswordHash(data) {
      return data.keys().hasAny(["passwordHash"]) ? data.passwordHash : null;
    }

    function validPublicShareOwnerWrappedKey(data) {
      return !data.keys().hasAny(["ownerWrappedShareKey"])
        || wrappedAesKeyPayload(data.ownerWrappedShareKey);
    }

    function validPublicSharePassword(data) {
      return !data.keys().hasAny(["passwordHash"])
        || validPublicSharePasswordHash(data.passwordHash);
    }

    function validPublicSharePasswordHash(passwordHash) {
      return passwordHash is map
        && passwordHash.keys().hasOnly(["version", "algorithm", "salt", "iterations", "hash"])
        && passwordHash.version == 2
        && passwordHash.algorithm == "PBKDF2-SHA-256"
        && passwordHash.salt is string
        && passwordHash.salt.size() >= 8
        && passwordHash.salt.size() <= 256
        && passwordHash.iterations is int
        && passwordHash.iterations >= 100000
        && passwordHash.iterations <= 1000000
        && passwordHash.hash is string
        && passwordHash.hash.size() >= 8
        && passwordHash.hash.size() <= 256;
    }

    function publicShareAttachmentMimeMatchesExtension(data) {
      return (data.extension == "pdf" && data.mimeType == "application/pdf")
        || (data.extension == "txt" && data.mimeType == "text/plain")
        || (data.extension == "md" && data.mimeType == "text/markdown")
        || (data.extension == "csv" && data.mimeType == "text/csv")
        || (data.extension == "json" && data.mimeType == "application/json")
        || (data.extension == "doc" && data.mimeType == "application/msword")
        || (data.extension == "docx" && data.mimeType == "application/vnd.openxmlformats-officedocument.wordprocessingml.document")
        || (data.extension == "xls" && data.mimeType == "application/vnd.ms-excel")
        || (data.extension == "xlsx" && data.mimeType == "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")
        || (data.extension == "ppt" && data.mimeType == "application/vnd.ms-powerpoint")
        || (data.extension == "pptx" && data.mimeType == "application/vnd.openxmlformats-officedocument.presentationml.presentation")
        || (data.extension == "hwp" && data.mimeType == "application/x-hwp")
        || (data.extension == "hwpx" && data.mimeType == "application/vnd.hancom.hwpx")
        || (data.extension == "png" && data.mimeType == "image/png")
        || (data.extension == "jpg" && data.mimeType == "image/jpeg")
        || (data.extension == "jpeg" && data.mimeType == "image/jpeg")
        || (data.extension == "webp" && data.mimeType == "image/webp")
        || (data.extension == "gif" && data.mimeType == "image/gif");
    }

    function validPublicShareAttachment(data) {
      return data.keys().hasOnly([
        "version",
        "algorithm",
        "fileName",
        "extension",
        "mimeType",
        "originalSize",
        "encryptedData",
        "iv",
        "sourceAttachmentId",
        "expiresAt",
        "createdAt"
      ])
      && data.version == 1
      && data.algorithm == "AES-GCM"
      && data.fileName is string
      && data.fileName.size() > 0
      && data.fileName.size() <= 100
      && data.extension in [
        "pdf",
        "txt",
        "md",
        "csv",
        "json",
        "doc",
        "docx",
        "xls",
        "xlsx",
        "ppt",
        "pptx",
        "hwp",
        "hwpx",
        "png",
        "jpg",
        "jpeg",
        "webp",
        "gif"
      ]
      && data.mimeType is string
      && data.mimeType.size() <= 120
      && publicShareAttachmentMimeMatchesExtension(data)
      && data.originalSize is int
      && data.originalSize > 0
      && data.originalSize <= 1000000
      && data.encryptedData is bytes
      && data.encryptedData.size() == data.originalSize + 16
      && data.encryptedData.size() <= 1000016
      && data.iv is bytes
      && data.iv.size() == 12
      && (!data.keys().hasAny(["sourceAttachmentId"]) || (data.sourceAttachmentId is string && data.sourceAttachmentId.size() <= 160))
      && data.expiresAt is timestamp
      && (!data.keys().hasAny(["createdAt"]) || data.createdAt is timestamp);
    }

    function rosterMatchesUser(data, uid) {
      return getAfter(userPath(uid)).data.displayName == data.displayName
        && getAfter(userPath(uid)).data.avatarText == data.avatarText
        && getAfter(userPath(uid)).data.color == data.color
        && getAfter(userPath(uid)).data.order == data.order
        && getAfter(userPath(uid)).data.quickKey == data.quickKey
        && getAfter(userPath(uid)).data.loginEmail == data.loginEmail
        && getAfter(userPath(uid)).data.isActive == data.isActive
        && getAfter(userPath(uid)).data.isAdmin == data.isAdmin;
    }

    function userMatchesRoster(data, uid) {
      return getAfter(rosterPath(uid)).data.displayName == data.displayName
        && getAfter(rosterPath(uid)).data.avatarText == data.avatarText
        && getAfter(rosterPath(uid)).data.color == data.color
        && getAfter(rosterPath(uid)).data.order == data.order
        && getAfter(rosterPath(uid)).data.quickKey == data.quickKey
        && getAfter(rosterPath(uid)).data.loginEmail == data.loginEmail
        && getAfter(rosterPath(uid)).data.isActive == data.isActive
        && getAfter(rosterPath(uid)).data.isAdmin == data.isAdmin;
    }

    function adminDeletesManagedUser(uid) {
      return adminUser()
        && uid != request.auth.uid
        && exists(userPath(uid))
        && exists(rosterPath(uid))
        && exists(userKeyPath(uid))
        && exists(quickLoginKeyPath(get(userPath(uid)).data.quickKey))
        && !existsAfter(userPath(uid))
        && !existsAfter(rosterPath(uid))
        && !existsAfter(userKeyPath(uid))
        && !existsAfter(quickLoginKeyPath(get(userPath(uid)).data.quickKey));
    }

    function validBootstrapTokenHash(value) {
      return value is string && value.size() == 64;
    }

    function validBootstrapAttempt(data, uid) {
      return data.keys().hasOnly(["uid", "setupTokenHash", "createdAt"])
        && data.uid == uid
        && validBootstrapTokenHash(data.setupTokenHash)
        && data.createdAt == request.time;
    }

    function validBootstrapGate(data) {
      return data.keys().hasOnly(["setupTokenHash", "createdAt"])
        && validBootstrapTokenHash(data.setupTokenHash)
        && data.createdAt is timestamp;
    }

    function bootstrapCreatesAdmin(uid) {
      return signedIn()
        && request.auth.uid == uid
        && !exists(bootstrapPath())
        && exists(bootstrapGatePath())
        && validBootstrapGate(get(bootstrapGatePath()).data)
        && existsAfter(bootstrapAttemptPath(uid))
        && validBootstrapAttempt(getAfter(bootstrapAttemptPath(uid)).data, uid)
        && getAfter(bootstrapAttemptPath(uid)).data.setupTokenHash == get(bootstrapGatePath()).data.setupTokenHash
        && getAfter(bootstrapPath()).data.adminUid == uid;
    }

    function firstAdminCreate(uid) {
      return bootstrapCreatesAdmin(uid)
        && getAfter(userPath(uid)).data.isAdmin == true
        && getAfter(userPath(uid)).data.isActive == true
        && getAfter(rosterPath(uid)).data.isAdmin == true
        && getAfter(userKeyPath(uid)).data.uid == uid
        && getAfter(quickLoginKeyPath(getAfter(userPath(uid)).data.quickKey)).data.uid == uid;
    }

    function legacyActiveDeleteMetadataAdded(data) {
      return !resource.data.keys().hasAny(["isDeleted"])
        && data.keys().hasAny(["isDeleted"])
        && data.isDeleted == false
        && !data.keys().hasAny(["deletedAt", "deletedBy"]);
    }

    function activeNoteUpdateAffectedKeys(keys, keysWithLegacyDeleteMetadata) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys)
        || (
          legacyActiveDeleteMetadataAdded(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(keysWithLegacyDeleteMetadata)
        );
    }

    function legacyActiveDeleteMetadataMigration(data) {
      return (adminUser() || noteParticipant(resource.data))
        && !noteDeleted(resource.data)
        && !noteDeleted(data)
        && legacyActiveDeleteMetadataAdded(data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isDeleted"]);
    }

    function adminCreatesUser(uid) {
      return adminUser()
        && getAfter(rosterPath(uid)).data.uid == uid
        && getAfter(userKeyPath(uid)).data.uid == uid
        && getAfter(quickLoginKeyPath(getAfter(userPath(uid)).data.quickKey)).data.uid == uid;
    }

    function noteContentUpdate(data) {
      return noteParticipant(data)
        && !noteDeleted(resource.data)
        && !noteDeleted(data)
        && data.type == resource.data.type
        && data.participantUids == resource.data.participantUids
        && data.wrappedKeys == resource.data.wrappedKeys
        && allowedShareTargets(data)
        && activeNoteUpdateAffectedKeys([
          "encryptedTitle",
          "encryptedBody",
          "updatedAt",
          "updatedBy"
        ], [
          "encryptedTitle",
          "encryptedBody",
          "updatedAt",
          "updatedBy",
          "isDeleted"
        ]);
    }

    function noteFolderUpdate(data) {
      return request.auth.uid == resource.data.ownerUid
        && resource.data.type == "personal"
        && data.type == "personal"
        && !noteDeleted(resource.data)
        && !noteDeleted(data)
        && data.participantUids == resource.data.participantUids
        && data.wrappedKeys == resource.data.wrappedKeys
        && data.encryptedTitle == resource.data.encryptedTitle
        && data.encryptedBody == resource.data.encryptedBody
        && data.updatedBy == request.auth.uid
        && validAssignedFolder(data)
        && activeNoteUpdateAffectedKeys([
          "folderId",
          "updatedAt",
          "updatedBy"
        ], [
          "folderId",
          "updatedAt",
          "updatedBy",
          "isDeleted"
        ]);
    }

    function ownerAccessUpdate(data) {
      return request.auth.uid == resource.data.ownerUid
        && !noteDeleted(resource.data)
        && !noteDeleted(data)
        && request.auth.uid in data.participantUids
        && data.encryptedTitle == resource.data.encryptedTitle
        && data.encryptedBody == resource.data.encryptedBody
        && validAssignedFolder(data)
        && activeNoteUpdateAffectedKeys([
          "type",
          "participantUids",
          "wrappedKeys",
          "folderId",
          "updatedAt",
          "updatedBy"
        ], [
          "type",
          "participantUids",
          "wrappedKeys",
          "folderId",
          "updatedAt",
          "updatedBy",
          "isDeleted"
        ]);
    }

    function noteSoftDeleteUpdate(data) {
      return !noteDeleted(resource.data)
        && canDeleteNote(resource.data)
        && data.isDeleted == true
        && data.deletedBy == request.auth.uid
        && data.updatedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "isDeleted",
          "deletedAt",
          "deletedBy",
          "updatedAt",
          "updatedBy"
        ]);
    }

    function noteRestoreUpdate(data) {
      return noteDeleted(resource.data)
        && canDeleteNote(resource.data)
        && !notePurged(resource.data)
        && data.isDeleted == false
        && !data.keys().hasAny(["deletedAt", "deletedBy"])
        && data.updatedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "isDeleted",
          "deletedAt",
          "deletedBy",
          "updatedAt",
          "updatedBy"
        ]);
    }

    function notePurgeUpdate(data) {
      return noteDeleted(resource.data)
        && canDeleteNote(resource.data)
        && data.isDeleted == true
        && data.isPurged == true
        && data.purgedBy == request.auth.uid
        && data.updatedBy == request.auth.uid
        && data.type == "personal"
        && data.participantUids == [request.auth.uid]
        && data.wrappedKeys.keys().hasOnly([request.auth.uid])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "type",
          "participantUids",
          "wrappedKeys",
          "encryptedTitle",
          "encryptedBody",
          "isPurged",
          "purgedAt",
          "purgedBy",
          "updatedAt",
          "savedAt",
          "updatedBy"
        ]);
    }

    function allowedShareTargets(data) {
      return data.participantUids.hasOnly([data.ownerUid])
        || (
          get(userPath(data.ownerUid)).data.isActive == true
          && get(userPath(data.ownerUid)).data.isAdmin == true
        )
        || (
          get(userPath(data.ownerUid)).data.keys().hasAny(["allowedShareTargetUids"])
          && data.participantUids.hasOnly(get(userPath(data.ownerUid)).data.allowedShareTargetUids)
        );
    }

    function ownerAllowsParticipant(data, uid) {
      return uid == data.ownerUid
        || (
          get(userPath(data.ownerUid)).data.isActive == true
          && get(userPath(data.ownerUid)).data.isAdmin == true
        )
        || (
          get(userPath(data.ownerUid)).data.keys().hasAny(["allowedShareTargetUids"])
          && uid in get(userPath(data.ownerUid)).data.allowedShareTargetUids
        );
    }

    function canReadNote(data) {
      return noteActive(data)
        && !notePurged(data)
        && (
          adminUser()
          || (activeSignedInUser() && data.ownerUid == request.auth.uid)
          || (noteParticipant(data) && ownerAllowsParticipant(data, request.auth.uid))
        );
    }

    function canReadDeletedNote(data) {
      return noteDeleted(data)
        && canDeleteNote(data);
    }

    function canReadNoteDocument(data) {
      return canReadNote(data) || canReadDeletedNote(data);
    }

    function canListNoteDocument(data) {
      return (
          canReadNote(data)
          && (
            !legacyActiveDeleteMetadata(data)
            || adminUser()
            || (activeSignedInUser() && data.ownerUid == request.auth.uid)
          )
        )
        || canReadDeletedNote(data);
    }

    function canDeleteNote(data) {
      return (activeSignedInUser() && data.ownerUid == request.auth.uid)
        || adminUser();
    }

    function canDeleteAttachment(noteData, attachmentData) {
      return adminUser()
        || (
          noteParticipant(noteData)
          && (noteData.ownerUid == request.auth.uid || attachmentData.uploadedBy == request.auth.uid)
        );
    }

    function publicShareNotRevoked(data) {
      return !data.keys().hasAny(["revokedAt", "revokedBy"]);
    }

    function publicShareActive(data) {
      return data.ready == true
        && publicShareNotRevoked(data)
        && data.expiresAt > request.time
        && validPublicSharePassword(data);
    }

    function publicShareOwner(data) {
      return activeSignedInUser() && data.ownerUid == request.auth.uid;
    }

    function validPublicShareCleanupQueue(data, shareId) {
      return data.keys().hasOnly(["shareId", "expiresAt", "createdAt"])
        && data.shareId == shareId
        && data.expiresAt is timestamp
        && data.createdAt == request.time;
    }

    function publicShareCleanupQueueCreated(shareId, shareData) {
      return existsAfter(publicShareCleanupQueuePath(shareId))
        && validPublicShareCleanupQueue(getAfter(publicShareCleanupQueuePath(shareId)).data, shareId)
        && getAfter(publicShareCleanupQueuePath(shareId)).data.expiresAt == shareData.expiresAt;
    }

    function publicShareCleanupQueueOwner(shareId) {
      return exists(publicSharePath(shareId))
        && publicShareOwner(get(publicSharePath(shareId)).data);
    }

    function validPublicShareAttachmentCleanupQueue(data, shareId, attachmentId) {
      return data.keys().hasOnly(["shareId", "attachmentId", "expiresAt", "createdAt"])
        && data.shareId == shareId
        && data.attachmentId == attachmentId
        && data.expiresAt is timestamp
        && data.createdAt == request.time;
    }

    function publicShareAttachmentCleanupQueueCreated(shareId, attachmentId, attachmentData) {
      return existsAfter(publicShareAttachmentCleanupQueuePath(shareId, attachmentId))
        && validPublicShareAttachmentCleanupQueue(
          getAfter(publicShareAttachmentCleanupQueuePath(shareId, attachmentId)).data,
          shareId,
          attachmentId
        )
        && getAfter(publicShareAttachmentCleanupQueuePath(shareId, attachmentId)).data.expiresAt == attachmentData.expiresAt
        && getAfter(publicShareAttachmentCleanupQueuePath(shareId, attachmentId)).data.expiresAt == getAfter(publicSharePath(shareId)).data.expiresAt;
    }

    function publicShareCreate(shareId, data) {
      return activeSignedInUser()
        && validPublicShare(data)
        && data.ownerUid == request.auth.uid
        && data.ready == false
        && data.attachmentCount == 0
        && data.keys().hasAny(["ownerWrappedShareKey"])
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && data.expiresAt > request.time
        && data.expiresAt <= request.time + duration.value(7, "d")
        && publicShareNotRevoked(data)
        && exists(notePath(data.sourceNoteId))
        && get(notePath(data.sourceNoteId)).data.ownerUid == request.auth.uid
        && canReadNote(get(notePath(data.sourceNoteId)).data)
        && publicShareCleanupQueueCreated(shareId, data);
    }

    function publicShareActivateUpdate(data) {
      return publicShareOwner(resource.data)
        && publicShareNotRevoked(resource.data)
        && publicShareNotRevoked(data)
        && resource.data.ready == false
        && data.ready == true
        && data.updatedAt == request.time
        && data.sourceNoteId == resource.data.sourceNoteId
        && data.ownerUid == resource.data.ownerUid
        && data.version == resource.data.version
        && data.encryptedTitle == resource.data.encryptedTitle
        && data.encryptedBody == resource.data.encryptedBody
        && data.createdAt == resource.data.createdAt
        && data.expiresAt == resource.data.expiresAt
        && publicSharePasswordHash(data) == publicSharePasswordHash(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["ready", "attachmentCount", "updatedAt"]);
    }

    function publicShareRevokeUpdate(data) {
      return publicShareOwner(resource.data)
        && publicShareNotRevoked(resource.data)
        && data.revokedAt == request.time
        && data.revokedBy == request.auth.uid
        && data.updatedAt == request.time
        && data.sourceNoteId == resource.data.sourceNoteId
        && data.ownerUid == resource.data.ownerUid
        && data.version == resource.data.version
        && data.encryptedTitle == resource.data.encryptedTitle
        && data.encryptedBody == resource.data.encryptedBody
        && data.attachmentCount == resource.data.attachmentCount
        && data.ready == resource.data.ready
        && data.createdAt == resource.data.createdAt
        && data.expiresAt == resource.data.expiresAt
        && publicSharePasswordHash(data) == publicSharePasswordHash(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["revokedAt", "revokedBy", "updatedAt"]);
    }

    function publicSharePasswordUpdate(data) {
      return publicShareOwner(resource.data)
        && publicShareNotRevoked(resource.data)
        && publicShareNotRevoked(data)
        && data.updatedAt == request.time
        && data.sourceNoteId == resource.data.sourceNoteId
        && data.ownerUid == resource.data.ownerUid
        && data.version == resource.data.version
        && data.encryptedTitle == resource.data.encryptedTitle
        && data.encryptedBody == resource.data.encryptedBody
        && data.attachmentCount == resource.data.attachmentCount
        && data.ready == resource.data.ready
        && data.createdAt == resource.data.createdAt
        && data.expiresAt == resource.data.expiresAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["passwordHash", "updatedAt"]);
    }

    function publicShareContentUpdate(data) {
      return publicShareOwner(resource.data)
        && publicShareNotRevoked(resource.data)
        && publicShareNotRevoked(data)
        && data.updatedAt == request.time
        && data.sourceNoteId == resource.data.sourceNoteId
        && data.ownerUid == resource.data.ownerUid
        && data.version == resource.data.version
        && data.ready == resource.data.ready
        && data.createdAt == resource.data.createdAt
        && data.expiresAt == resource.data.expiresAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "encryptedTitle",
          "encryptedBody",
          "attachmentCount",
          "passwordHash",
          "updatedAt"
        ]);
    }

    match /publicLoginRoster/{uid} {
      allow read: if true;
      allow create: if validRoster(request.resource.data, uid)
        && (firstAdminCreate(uid) || adminCreatesUser(uid));
      allow update: if adminUser()
        && validRoster(request.resource.data, uid)
        && rosterMatchesUser(request.resource.data, uid)
        && getAfter(userPath(uid)).data.quickKey == request.resource.data.quickKey
        && getAfter(quickLoginKeyPath(request.resource.data.quickKey)).data.uid == uid;
      allow delete: if adminDeletesManagedUser(uid);
    }

    match /users/{uid} {
      allow read: if activeSignedInUser() || (signedIn() && request.auth.uid == uid);
      allow create: if validUserProfile(request.resource.data, uid)
        && (firstAdminCreate(uid) || adminCreatesUser(uid));
      allow update: if adminUser()
        && validUserProfile(request.resource.data, uid)
        && userMatchesRoster(request.resource.data, uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "displayName",
          "avatarText",
          "color",
          "quickKey",
          "order",
          "isActive",
          "isAdmin",
          "role",
          "allowedShareTargetUids",
          "updatedAt"
        ])
        && getAfter(rosterPath(uid)).data.quickKey == request.resource.data.quickKey
        && getAfter(quickLoginKeyPath(request.resource.data.quickKey)).data.uid == uid;
      allow delete: if adminDeletesManagedUser(uid);
    }

    match /userKeys/{uid} {
      allow read: if activeSignedInUser() && request.auth.uid == uid;
      allow create: if validUserKey(request.resource.data, uid)
        && (firstAdminCreate(uid) || adminCreatesUser(uid));
      allow update: if activeSignedInUser()
        && request.auth.uid == uid
        && validUserKey(request.resource.data, uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.publicKeyJwk == resource.data.publicKeyJwk
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "encryptedPrivateKeyJwk",
          "kdfSalt",
          "kdfIterations",
          "pendingEncryptedPrivateKeyJwk",
          "pendingKdfSalt",
          "pendingKdfIterations",
          "pendingCreatedAt",
          "updatedAt"
        ]);
      allow delete: if adminDeletesManagedUser(uid);
    }

    match /userPreferences/{uid} {
      allow read: if activeSignedInUser() && request.auth.uid == uid;
      allow create: if activeSignedInUser()
        && request.auth.uid == uid
        && validUserPreferences(request.resource.data, uid)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if activeSignedInUser()
        && request.auth.uid == uid
        && validUserPreferences(request.resource.data, uid)
        && request.resource.data.uid == resource.data.uid
        && (
          (
            !request.resource.data.keys().hasAny(["createdAt"])
            && !resource.data.keys().hasAny(["createdAt"])
          )
          || request.resource.data.createdAt == resource.data.createdAt
        )
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "defaultHome",
          "scheduleDefaultView",
          "updatedAt"
        ]);
      allow delete: if false;
    }

    match /scheduleTasks/{taskId} {
      allow read: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid;
      allow create: if activeSignedInUser()
        && validScheduleTask(request.resource.data, request.auth.uid)
        && request.resource.data.status == "active"
        && request.resource.data.completedAt == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid
        && validScheduleTask(request.resource.data, request.auth.uid)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.wrappedKeys == resource.data.wrappedKeys
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "dueDate",
          "dueTimeMinutes",
          "startDate",
          "endDate",
          "startTimeMinutes",
          "endTimeMinutes",
          "color",
          "sortOrder",
          "progressPercent",
          "isImportant",
          "isUrgent",
          "encryptedTitle",
          "encryptedDetails",
          "updatedBy",
          "updatedAt",
          "completedAt"
        ]);
      allow delete: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /recurringHabits/{habitId} {
      allow read: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid;
      allow create: if activeSignedInUser()
        && validRecurringHabit(request.resource.data, request.auth.uid)
        && request.resource.data.status == "active"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid
        && validRecurringHabit(request.resource.data, request.auth.uid)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.wrappedKeys == resource.data.wrappedKeys
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "slot",
          "icon",
          "color",
          "sortOrder",
          "encryptedTitle",
          "encryptedDetails",
          "updatedBy",
          "updatedAt"
        ]);
      allow delete: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /recurringHabitCheckIns/{checkInId} {
      allow read: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid;
      allow create: if activeSignedInUser()
        && validRecurringHabitCheckIn(request.resource.data, request.auth.uid, checkInId)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid
        && validRecurringHabitCheckIn(request.resource.data, request.auth.uid, checkInId)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.habitId == resource.data.habitId
        && request.resource.data.date == resource.data.date
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "checkedAt",
          "updatedAt"
        ]);
      allow delete: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /noteFolders/{folderId} {
      allow read: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid;
      allow create: if activeSignedInUser()
        && validNoteFolder(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid
        && validNoteFolder(request.resource.data)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["name", "color", "updatedAt"]);
      allow delete: if activeSignedInUser()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /quickLoginKeys/{quickKey} {
      allow read: if adminUser();
      allow create: if validQuickLoginKey(request.resource.data, request.resource.data.uid)
        && (firstAdminCreate(request.resource.data.uid) || adminCreatesUser(request.resource.data.uid));
      allow update: if adminUser()
        && validQuickLoginKey(request.resource.data, request.resource.data.uid)
        && resource.data.uid == request.resource.data.uid;
      allow delete: if adminUser();
    }

    match /system/bootstrap {
      allow read: if adminUser();
      allow create: if signedIn()
        && !exists(bootstrapPath())
        && request.resource.data.keys().hasOnly(["adminUid", "createdAt"])
        && request.resource.data.adminUid == request.auth.uid
        && getAfter(userPath(request.auth.uid)).data.isAdmin == true
        && getAfter(userPath(request.auth.uid)).data.isActive == true;
      allow update, delete: if false;
    }

    match /system/bootstrapGate {
      allow read, create, update, delete: if false;
    }

    match /system/bootstrapAttempts/attempts/{uid} {
      allow read, update, delete: if false;
      allow create: if validBootstrapAttempt(request.resource.data, uid)
        && firstAdminCreate(uid);
    }

    match /notes/{noteId} {
      allow get: if canReadNoteDocument(resource.data);
      allow list: if canListNoteDocument(resource.data);
      allow create: if activeSignedInUser()
        && validNote(request.resource.data)
        && request.resource.data.isDeleted == false
        && !request.resource.data.keys().hasAny(["deletedAt", "deletedBy"])
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.participantUids
        && allowedShareTargets(request.resource.data)
        && validAssignedFolder(request.resource.data);
      allow update: if validNote(request.resource.data)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          noteContentUpdate(request.resource.data)
          || noteFolderUpdate(request.resource.data)
          || (ownerAccessUpdate(request.resource.data) && allowedShareTargets(request.resource.data))
          || legacyActiveDeleteMetadataMigration(request.resource.data)
          || noteSoftDeleteUpdate(request.resource.data)
          || noteRestoreUpdate(request.resource.data)
          || notePurgeUpdate(request.resource.data)
        );
      allow delete: if false;

      match /history/{historyId} {
        allow read: if exists(notePath(noteId))
          && canReadNoteHistory(resource.data, get(notePath(noteId)).data);
        allow create: if validNoteHistory(request.resource.data, noteId)
          && historyMatchesNoteMutation(request.resource.data, noteId);
        allow update: if validNoteHistory(request.resource.data, noteId)
          && resource.data.actorUid == request.auth.uid
          && resource.data.action == "content"
          && request.resource.data.action == "content"
          && historyMatchesNoteMutation(request.resource.data, noteId);
        allow delete: if exists(notePath(noteId))
          && noteDeleted(get(notePath(noteId)).data)
          && notePurged(get(notePath(noteId)).data)
          && canDeleteNote(get(notePath(noteId)).data);
      }

      match /attachments/{attachmentId} {
        allow read: if exists(notePath(noteId))
          && (
            canReadNote(get(notePath(noteId)).data)
            || canReadDeletedNote(get(notePath(noteId)).data)
          );
        allow create: if exists(notePath(noteId))
          && !noteDeleted(get(notePath(noteId)).data)
          && noteParticipant(get(notePath(noteId)).data)
          && validAttachment(request.resource.data, noteId)
          && request.resource.data.uploadedBy == request.auth.uid;
        allow update: if false;
        allow delete: if exists(notePath(noteId))
          && canDeleteAttachment(get(notePath(noteId)).data, resource.data);
      }
    }

    match /publicNoteShares/{shareId} {
      allow get: if publicShareActive(resource.data) || publicShareOwner(resource.data);
      allow list: if publicShareOwner(resource.data);
      allow create: if publicShareCreate(shareId, request.resource.data);
      allow update: if validPublicShare(request.resource.data)
        && (
          publicShareActivateUpdate(request.resource.data)
          || publicShareRevokeUpdate(request.resource.data)
          || publicSharePasswordUpdate(request.resource.data)
          || publicShareContentUpdate(request.resource.data)
        );
      allow delete: if publicShareOwner(resource.data);

      match /attachments/{attachmentId} {
        allow read: if exists(publicSharePath(shareId))
          && (
            publicShareActive(get(publicSharePath(shareId)).data)
            || publicShareOwner(get(publicSharePath(shareId)).data)
          );
        allow create: if exists(publicSharePath(shareId))
          && publicShareOwner(get(publicSharePath(shareId)).data)
          && publicShareNotRevoked(get(publicSharePath(shareId)).data)
          && get(publicSharePath(shareId)).data.expiresAt > request.time
          && request.resource.data.expiresAt == get(publicSharePath(shareId)).data.expiresAt
          && validPublicShareAttachment(request.resource.data)
          && request.resource.data.createdAt == request.time
          && publicShareAttachmentCleanupQueueCreated(shareId, attachmentId, request.resource.data);
        allow update: if false;
        allow delete: if exists(publicSharePath(shareId))
          && publicShareOwner(get(publicSharePath(shareId)).data);
      }
    }

    match /publicShareCleanupQueue/{shareId} {
      allow get, list: if publicShareCleanupQueueOwner(shareId);
      allow create: if validPublicShareCleanupQueue(request.resource.data, shareId)
        && existsAfter(publicSharePath(shareId))
        && publicShareOwner(getAfter(publicSharePath(shareId)).data)
        && request.resource.data.expiresAt == getAfter(publicSharePath(shareId)).data.expiresAt;
      allow update: if false;
      allow delete: if false;

      match /publicShareAttachmentCleanupQueue/{attachmentId} {
        allow get, list: if exists(publicSharePath(shareId))
          && publicShareOwner(get(publicSharePath(shareId)).data);
        allow create: if validPublicShareAttachmentCleanupQueue(request.resource.data, shareId, attachmentId)
          && existsAfter(publicSharePath(shareId))
          && existsAfter(publicShareAttachmentPath(shareId, attachmentId))
          && publicShareOwner(getAfter(publicSharePath(shareId)).data)
          && request.resource.data.expiresAt == getAfter(publicSharePath(shareId)).data.expiresAt
          && request.resource.data.expiresAt == getAfter(publicShareAttachmentPath(shareId, attachmentId)).data.expiresAt;
        allow update: if false;
        allow delete: if false;
      }
    }

    match /noteUserStates/{noteId}/users/{uid} {
      allow read: if exists(notePath(noteId))
        && canReadNoteDocument(get(notePath(noteId)).data);
      allow create, update: if activeSignedInUser()
        && request.auth.uid == uid
        && exists(notePath(noteId))
        && !noteDeleted(get(notePath(noteId)).data)
        && noteParticipant(get(notePath(noteId)).data)
        && ownerAllowsParticipant(get(notePath(noteId)).data, request.auth.uid)
        && validNoteUserState(request.resource.data, noteId, uid);
      allow delete: if false;
    }

    match /activeNotes/{uid} {
      allow read: if activeSignedInUser() && request.auth.uid == uid;
      allow create, update: if activeSignedInUser()
        && request.auth.uid == uid
        && validActiveNote(request.resource.data, uid)
        && (
          request.resource.data.noteId == null
          || (
            exists(notePath(request.resource.data.noteId))
            && noteParticipant(get(notePath(request.resource.data.noteId)).data)
            && !noteDeleted(get(notePath(request.resource.data.noteId)).data)
          )
        );
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
